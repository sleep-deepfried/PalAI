# =============================================================================
# Supabase
# =============================================================================
# NEXT_PUBLIC_ vars are exposed to the browser; non-prefixed are server-only.
# The app falls back to NEXT_PUBLIC_ if the server-only vars aren't set,
# so you only need one set. NEXT_PUBLIC_ is fine for URL and anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key is secret — never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# NextAuth
# =============================================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# =============================================================================
# Google OAuth
# =============================================================================
# Required for "Sign in with Google". Get credentials from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Email OTP (SMTP)
# =============================================================================
# Required for passwordless email sign-in. Configure with your SMTP provider.
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

# =============================================================================
# Google Gemini AI
# =============================================================================
#GEMINI_API_KEY=
# Model for image diagnosis (needs vision capability)
# Default: gemini-2.5-flash (gemini-2.5-pro has 0 free-tier quota)
GEMINI_DIAGNOSE_MODEL=gemini-2.5-flash
# Model for treatment text generation (text-only, cheaper/faster)
GEMINI_TREATMENT_MODEL=gemini-2.5-flash

# =============================================================================
# Optional: PalAI Hub (legacy Raspberry Pi + camera MJPEG on scan page)
# Thesis IoT uses ESP32 + Supabase REST instead (see firmware/esp32_palai_iot).
# =============================================================================
# NEXT_PUBLIC_PI_TUNNEL_URL=
